      "name": "Ocena LLM-judge",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [2176, 112],
      "parameters": { "promptType": "define", "hasOutputParser": true, "text": "=Jestes audytorem jakosci RAG. Ocen, czy ODPOWIEDZ jest ugruntowana w KONTEKSCIE (nie w wiedzy ogolnej).\n\nPytanie: {{ $(\"Zloz kontekst\").item.json.q }}\n\nKontekst:\n{{ $(\"Zloz kontekst\").item.json.context }}\n\nOdpowiedz: {{ $json.text }}\n\nZwroc: faithfulness (0-1), relevance (0-1), grounded (true/false), hallucination_risk (low/medium/high), reasoning (1 zdanie)." }
    },
