    {
      "id": "afbacd96-4861-4a87-96f5-422330e19b72",
      "name": "Zloz kontekst",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1600, 112],
      "parameters": { "mode": "runOnceForAllItems", "language": "javaScript", "jsCode": "const docs=$input.all();const q=$('Zapytanie').first().json.q;const parts=[];const sources=[];docs.forEach((d,i)=>{const j=d.json||{};const t=(j.document&&j.document.pageContent)||j.pageContent||j.text||j.content||JSON.stringify(j);const src=(j.metadata&&(j.metadata.source||j.metadata.id))||(j.document&&j.document.metadata&&j.document.metadata.source)||('doc'+(i+1));parts.push('['+(i+1)+'] '+t);sources.push(src);});return [{json:{q:q,context:parts.join('\\n'),sources:sources}}];" }
    },
    {
      "id": "da9eb259-bd28-4502-b9fc-746cdd176fc1",
      "name": "Odpowiedz RAG",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [1824, 112],
      "parameters": { "promptType": "define", "text": "=Pytanie: {{ $json.q }}\n\nKontekst (fragmenty bazy wiedzy):\n{{ $json.context }}\n\nOdpowiedz na pytanie WYLACZNIE na podstawie kontekstu powyzej. Jesli kontekst nie zawiera odpowiedzi, napisz dokladnie: \"Nie mam tej informacji w bazie wiedzy.\" Odpowiadaj po polsku, zwiezle." }
    },
