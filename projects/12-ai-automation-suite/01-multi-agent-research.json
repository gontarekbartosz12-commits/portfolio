      "id": "f4d98adb-609c-4769-af62-84004a95682b",
      "name": "Critique Schema",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        1904,
        128
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Improve and finalize the research report below by addressing the editor critique. Keep Markdown formatting.\n\n--- REPORT ---\n{{ $(\"Synthesize Report\").item.json.output }}\n\n--- CRITIQUE ---\n{{ JSON.stringify($json.output) }}",
        "options": {
          "systemMessage": "You are a senior editor. Apply the critique and return only the final, polished Markdown report."
        }
      },
      "id": "daf67990-c8c0-4b9e-bee5-68163fca756f",
      "name": "Revise Report",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        2064,
        304
      ],
      "executeOnce": true
    },
    {
      "parameters": {
        "model": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-5-mini"
        },
        "builtInTools": {},
        "options": {}
      },
      "id": "01282c4f-24df-4c01-b20d-d5099f6b3776",
      "name": "Reviser Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
