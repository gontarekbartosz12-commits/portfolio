        "jsCode": "return [\n{json:{source:\"Refund Policy\",text:\"Refunds: customers can request a full refund within 30 days of delivery. Orders that arrive more than 7 days late qualify for a full refund or a 20% discount voucher.\"}},\n{json:{source:\"Shipping Policy\",text:\"Standard shipping takes 3-5 business days. Delays beyond 7 days are eligible for compensation under the Refund Policy.\"}},\n{json:{source:\"Returns Policy\",text:\"Returns: items can be returned within 30 days in original condition. Return shipping is free for defective items, otherwise paid by the customer.\"}},\n{json:{source:\"Warranty Policy\",text:\"All products include a 12-month warranty covering manufacturing defects. Warranty claims require an order number and photos.\"}},\n{json:{source:\"Account Help\",text:\"Password resets are done via the Forgot Password link. Account data deletion requests are handled within 14 days.\"}},\n{json:{source:\"Support Hours\",text:\"Human support is available Monday to Friday, 9:00-17:00 CET. Outside these hours, replies may be delayed.\"}}\n];"
