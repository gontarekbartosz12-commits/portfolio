    {
      "parameters": {
        "promptType": "define",
        "text": "=Customer ticket:\nSubject: {{ $(\"Build Query\").item.json.subject }}\nMessage: {{ $(\"Build Query\").item.json.message }}\nCategory: {{ $(\"Build Query\").item.json.category }}\n\nRelevant knowledge base context (JSON):\n{{ JSON.stringify($json.context) }}\n\nWrite a helpful, empathetic support reply grounded ONLY in the context above. Cite the relevant policy by name. If the context does not cover the question, do not invent an answer - state that you will escalate to a human agent.",
        "options": {
          "systemMessage": "You are a senior customer support agent. Be concise, warm and accurate. Never invent policies."
        }
      },
